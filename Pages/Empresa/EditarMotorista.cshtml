@page "{id:int}"
@model Eva.Pages.Empresa.EditarMotoristaModel
@{
    ViewData["Title"] = "Editar Motorista - Eva";
    bool isLocked = Model.PendenciaStatus == "EM_ANALISE";
}

<div class="container mt-5 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Empresa/MinhaEmpresa">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/Empresa/MeusMotoristas">Meus Motoristas</a></li>
            <li class="breadcrumb-item active">Editar</li>
        </ol>
    </nav>

    @if (isLocked)
    {
        <div class="alert alert-warning mb-4 shadow-sm" role="alert">
            <i class="bi bi-lock-fill me-2"></i>
            <strong>Acesso Bloqueado:</strong> Este motorista está em análise por um analista e não pode ser alterado no momento.
        </div>
    }

    <div class="row">
        <div class="col-lg-7">
            <div class="card shadow mb-4">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Dados do Motorista</h5>
                    @switch (Model.PendenciaStatus)
                    {
                        case "AGUARDANDO_ANALISE":
                            <span class="badge bg-warning text-dark border border-light"><i class="bi bi-hourglass-split"></i> Aguardando</span>
                            break;
                        case "EM_ANALISE":
                            <span class="badge bg-info text-dark border border-light"><i class="bi bi-search"></i> Em Análise</span>
                            break;
                        case "APROVADO":
                            <span class="badge bg-success border border-light"><i class="bi bi-check-circle"></i> Aprovado</span>
                            break;
                        case "REJEITADO":
                            <span class="badge bg-danger border border-light"><i class="bi bi-x-circle"></i> Rejeitado</span>
                            break;
                    }
                </div>
                <div class="card-body">
                    <form method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Motorista.Id" />

                        <fieldset disabled="@(isLocked ? "disabled" : null)">
                            <div class="row">
                                <div class="col-md-12 mb-3">
                                    <label asp-for="Motorista.Nome" class="form-label fw-bold">Nome Completo</label>
                                    <input asp-for="Motorista.Nome" class="form-control" />
                                    <span asp-validation-for="Motorista.Nome" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Motorista.Cpf" class="form-label fw-bold">CPF</label>
                                    <input asp-for="Motorista.Cpf" class="form-control" />
                                    <span asp-validation-for="Motorista.Cpf" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Motorista.Cnh" class="form-label fw-bold">CNH</label>
                                    <input asp-for="Motorista.Cnh" class="form-control" />
                                    <span asp-validation-for="Motorista.Cnh" class="text-danger small"></span>
                                </div>
                                <div class="col-md-12 mb-3">
                                    <label asp-for="Motorista.Email" class="form-label fw-bold">E-mail</label>
                                    <input asp-for="Motorista.Email" type="email" class="form-control" />
                                    <span asp-validation-for="Motorista.Email" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="d-flex justify-content-end gap-2 mt-4 border-top pt-3">
                                <a href="/Empresa/MeusMotoristas" class="btn btn-outline-secondary">Voltar</a>
                                @if (!isLocked)
                                {
                                    <button type="submit" class="btn btn-primary px-4">Salvar Alterações</button>
                                }
                            </div>
                        </fieldset>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow border-0">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="bi bi-file-earmark-person me-2"></i>Documentação</h5>
                </div>
                <div class="card-body bg-light">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="fw-bold text-secondary mb-0">CNH (Habilitação)</h6>
                            @* Interface Fix: Hide button if document already exists *@
                            @if (!isLocked && !Model.Cnhs.Any())
                            {
                                <button class="btn btn-sm btn-outline-primary" onclick="document.getElementById('fileInput').click()">
                                    <i class="bi bi-upload"></i> Enviar Nova
                                </button>
                            }
                        </div>

                        @if (!Model.Cnhs.Any())
                        {
                            <div class="alert alert-light border border-dashed text-center text-muted">
                                <i class="bi bi-cloud-upload display-6 d-block mb-2"></i>
                                Nenhum documento anexado.
                            </div>
                        }
                        else
                        {
                            <ul class="list-group list-group-flush shadow-sm rounded">
                                @foreach (var doc in Model.Cnhs)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <div class="text-truncate me-2" title="@doc.NomeArquivo">
                                            <i class="bi bi-file-earmark-person text-primary me-1"></i>
                                            <small class="fw-bold">@doc.NomeArquivo</small>
                                            <div class="text-muted" style="font-size: 0.75rem">
                                                @doc.DataUpload.ToString("dd/MM/yyyy HH:mm")
                                            </div>
                                        </div>
                                        @if (!isLocked)
                                        {
                                            @* Bug Fix: Added asp-route-id to deletion form *@
                                            <form method="post" asp-page-handler="DeleteDoc" asp-route-id="@Model.Motorista.Id" class="d-inline">
                                                <input type="hidden" name="docId" value="@doc.Id" />
                                                <button type="submit" class="btn btn-link text-danger p-0 border-0" title="Excluir">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Bug Fix: Added asp-route-id *@
<form id="uploadForm" method="post" enctype="multipart/form-data" asp-page-handler="Upload" asp-route-id="@Model.Motorista.Id" style="display:none">
    <input type="file" asp-for="UploadArquivo" id="fileInput" accept=".pdf" onchange="document.getElementById('uploadForm').submit()" />
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}