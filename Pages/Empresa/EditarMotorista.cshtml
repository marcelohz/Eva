@page "{id:int}"
@model Eva.Pages.Empresa.EditarMotoristaModel
@{
    ViewData["Title"] = "Editar Motorista - Fretamento Eventual";
    bool isLocked = SubmissaoWorkflow.EstaBloqueadaParaEmpresa(Model.PendenciaStatus ?? "");
}

<div class="container mt-5 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Empresa/MinhaEmpresa">Painel</a></li>
            <li class="breadcrumb-item"><a href="/Empresa/MeusMotoristas">Meus Motoristas</a></li>
            <li class="breadcrumb-item active">Editar</li>
        </ol>
    </nav>

    @if (isLocked)
    {
        <div class="alert alert-warning mb-4 shadow-sm" role="alert">
            <i class="bi bi-lock-fill me-2"></i>
            <strong>Acesso Bloqueado:</strong> Este motorista est횄징 em an횄징lise por um analista e n횄짙o pode ser alterado no momento.
        </div>
    }

    @if (Model.PendenciaStatus == SubmissaoWorkflow.Rejeitada && !string.IsNullOrEmpty(Model.ObservacaoGeralRejeicao))
    {
        <div class="alert alert-danger mb-4 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Rejei횄짠횄짙o da submiss횄짙o:</strong>
            <div class="mt-2 preserve-newlines"><strong>Observa횄짠횄짙o geral da rejei횄짠횄짙o:</strong> @Model.ObservacaoGeralRejeicao</div>
        </div>
    }

    @if (Model.PendenciaStatus == SubmissaoWorkflow.Rejeitada && !string.IsNullOrEmpty(Model.MotivoRejeicaoDados))
    {
        <div class="alert alert-warning mb-4 shadow-sm" role="alert">
            <i class="bi bi-file-earmark-text-fill me-2"></i>
            <strong>Dados cadastrais rejeitados:</strong>
            <div class="mt-2 preserve-newlines"><strong>Motivo da rejei횄짠횄짙o dos dados:</strong> @Model.MotivoRejeicaoDados</div>
        </div>
    }

    <div id="page-feedback">
        @if (!string.IsNullOrWhiteSpace(Model.FeedbackSucesso))
        {
            <div class="alert alert-success mb-4 shadow-sm" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@Model.FeedbackSucesso
            </div>
        }
    </div>

    <div class="row">
        <div class="col-lg-7">
            <div class="card shadow mb-4">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Dados do Motorista</h5>
                    <span class="badge @SubmissaoWorkflow.GetBadgeClass(Model.PendenciaStatus) border border-light"><i class="bi @SubmissaoWorkflow.GetBadgeIcon(Model.PendenciaStatus)"></i> @SubmissaoWorkflow.GetDisplayLabel(Model.PendenciaStatus)</span>
                </div>
                <div class="card-body">
                    <form method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="Input.Id" />

                        <fieldset disabled="@(isLocked ? "disabled" : null)">
                            <div class="row">
                                <div class="col-md-12 mb-3">
                                    <label asp-for="Input.Nome" class="form-label fw-bold">Nome Completo</label>
                                    <input asp-for="Input.Nome" class="form-control" />
                                    <span asp-validation-for="Input.Nome" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.Cpf" class="form-label fw-bold">CPF</label>
                                    <input asp-for="Input.Cpf" class="form-control" />
                                    <span asp-validation-for="Input.Cpf" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.Cnh" class="form-label fw-bold">CNH</label>
                                    <input asp-for="Input.Cnh" class="form-control" />
                                    <span asp-validation-for="Input.Cnh" class="text-danger small"></span>
                                </div>
                                <div class="col-md-12 mb-3">
                                    <label asp-for="Input.Email" class="form-label fw-bold">E-mail</label>
                                    <input asp-for="Input.Email" type="email" class="form-control" />
                                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="d-flex justify-content-end gap-2 mt-4 border-top pt-3">
                                <a href="/Empresa/MeusMotoristas" class="btn btn-outline-secondary">Voltar</a>
                                @if (!isLocked)
                                {
                                    <button type="submit" class="btn btn-primary px-4">Salvar Altera횄짠횄쨉es</button>
                                    <button type="submit" asp-page-handler="Enviar" class="btn btn-success px-4" onclick="return confirm('Deseja realmente enviar cadastro para an횄징lise?\nCertifique-se que todos dados e documentos est횄짙o corretos.');">Enviar para an횄징lise</button>
                                }
                            </div>
                        </fieldset>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow border-0">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="bi bi-file-earmark-person me-2"></i>Documenta횄짠횄짙o</h5>
                </div>
                <div class="card-body bg-light" id="doc-section-container">
                    <partial name="_MotoristaDocs" model="Model" />
                </div>
            </div>
        </div>
    </div>
</div>

<form id="uploadForm" method="post" enctype="multipart/form-data" asp-page-handler="Upload" asp-route-id="@Model.Input.Id" style="display:none">
    <input type="file" asp-for="UploadArquivo" id="fileInput" accept=".pdf"
           onchange="evaPerformAsyncAction('uploadForm', 'doc-section-container')" />
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


