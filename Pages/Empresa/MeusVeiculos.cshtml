@page
@model Eva.Pages.Empresa.MeusVeiculosModel
@{
    ViewData["Title"] = "Meus Veículos - Eva";
}

<div class="container mt-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Empresa/MinhaEmpresa">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Meus Veículos</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">Frota de Veículos</h1>
            <p class="text-muted">Gerencie os veículos cadastrados na sua empresa.</p>
        </div>
        <a href="/Empresa/NovoVeiculo" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Novo Veículo
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Placa</th>
                            <th>Modelo / Marca</th>
                            <th>Ano (Fab/Mod)</th>
                            <th>Lugares</th>
                            <th>Cor</th>
                            <th class="text-end pe-4">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Veiculos == null || !Model.Veiculos.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-truck display-4 d-block mb-2"></i>
                                    Nenhum veículo encontrado.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var v in Model.Veiculos)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="badge bg-dark text-uppercase p-2" style="letter-spacing: 1px;">
                                            @v.Placa
                                        </span>
                                    </td>
                                    <td class="fw-bold text-secondary">
                                        @(v.Modelo ?? "Não informado")
                                    </td>
                                    <td>
                                        @(v.AnoFabricacao?.ToString() ?? "-") / @(v.ModeloAno?.ToString() ?? "-")
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            @(v.NumeroLugares?.ToString() ?? "0")
                                        </span>
                                    </td>
                                    <td>
                                        @(v.CorPrincipalNome ?? "-")
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            <a href="/Empresa/EditarVeiculo/@v.Placa" class="btn btn-sm btn-outline-primary" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-outline-danger" title="Excluir" data-bs-toggle="modal" data-bs-target="#deleteModal" data-placa="@v.Placa">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel"><i class="bi bi-exclamation-triangle-fill"></i> Confirmar Exclusão</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Tem certeza que deseja excluir o veículo de placa <strong id="modalVeiculoPlaca"></strong>?</p>
                <p class="text-danger small mb-0">Esta ação não pode ser desfeita.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form method="post" asp-page-handler="Delete">
                    <input type="hidden" name="placa" id="modalInputPlaca" value="" />
                    <button type="submit" class="btn btn-danger">Sim, Excluir</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Listen for the modal to open
        var deleteModal = document.getElementById('deleteModal')
        deleteModal.addEventListener('show.bs.modal', function (event) {
            // Button that triggered the modal
            var button = event.relatedTarget

            // Extract info from data-placa attribute
            var placa = button.getAttribute('data-placa')

            // Update the modal's text and hidden input value
            var modalPlacaText = deleteModal.querySelector('#modalVeiculoPlaca')
            var modalInputPlaca = deleteModal.querySelector('#modalInputPlaca')

            modalPlacaText.textContent = placa
            modalInputPlaca.value = placa
        })
    </script>
}