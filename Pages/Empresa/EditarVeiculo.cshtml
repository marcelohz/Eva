@page "{id}"
@model Eva.Pages.Empresa.EditarVeiculoModel
@{
    ViewData["Title"] = "Editar Veículo - Eva";
}

<div class="container mt-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Empresa/MinhaEmpresa">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/Empresa/MeusVeiculos">Meus Veículos</a></li>
            <li class="breadcrumb-item active">Editar</li>
        </ol>
    </nav>

    <div class="card shadow">
        <div class="card-header bg-dark text-white">
            <h1 class="h4 mb-0">Editar Veículo: @Model.Input.Placa</h1>
        </div>
        <div class="card-body">
            <form method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Input.Placa" class="form-label fw-bold">Placa</label>
                        <input asp-for="Input.Placa" class="form-control bg-light" readonly />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Input.Modelo" class="form-label fw-bold">Modelo / Marca</label>
                        <input asp-for="Input.Modelo" class="form-control" />
                        <span asp-validation-for="Input.Modelo" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Input.PotenciaMotor" class="form-label fw-bold">Potência (cv)</label>
                        <input asp-for="Input.PotenciaMotor" type="number" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Input.VeiculoCombustivelNome" class="form-label fw-bold">Combustível</label>
                        <input asp-for="Input.VeiculoCombustivelNome" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Input.NumeroLugares" class="form-label fw-bold">Nº de Lugares</label>
                        <input asp-for="Input.NumeroLugares" type="number" class="form-control" />
                        <span asp-validation-for="Input.NumeroLugares" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Input.AnoFabricacao" class="form-label fw-bold">Ano Fabricação</label>
                        <input asp-for="Input.AnoFabricacao" type="number" class="form-control" />
                        <span asp-validation-for="Input.AnoFabricacao" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Input.ModeloAno" class="form-label fw-bold">Ano Modelo</label>
                        <input asp-for="Input.ModeloAno" type="number" class="form-control" />
                        <span asp-validation-for="Input.ModeloAno" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a href="/Empresa/MeusVeiculos" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary px-4">Salvar Alterações</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}