@page "{id}"
@model Eva.Pages.Empresa.EditarVeiculoModel
@{
    ViewData["Title"] = "Editar Veículo - Eva";
    bool isLocked = Model.PendenciaStatus == "EM_ANALISE";
}

<div class="container mt-5 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Empresa/MinhaEmpresa">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/Empresa/MeusVeiculos">Meus Veiculos</a></li>
            <li class="breadcrumb-item active">Editar</li>
        </ol>
    </nav>

    @if (isLocked)
    {
        <div class="alert alert-warning mb-4 shadow-sm" role="alert">
            <i class="bi bi-lock-fill me-2"></i>
            <strong>Acesso Bloqueado:</strong> Este veículo está em análise por um analista e não pode ser alterado no momento.
        </div>
    }

    <div class="row">
        <div class="col-lg-7">
            <div class="card shadow mb-4">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Dados do Veículo</h5>
                    @switch (Model.PendenciaStatus)
                    {
                        case "AGUARDANDO_ANALISE":
                            <span class="badge bg-warning text-dark border border-light"><i class="bi bi-hourglass-split"></i> Aguardando</span>
                            break;
                        case "EM_ANALISE":
                            <span class="badge bg-info text-dark border border-light"><i class="bi bi-search"></i> Em Análise</span>
                            break;
                        case "APROVADO":
                            <span class="badge bg-success border border-light"><i class="bi bi-check-circle"></i> Aprovado</span>
                            break;
                        case "REJEITADO":
                            <span class="badge bg-danger border border-light"><i class="bi bi-x-circle"></i> Rejeitado</span>
                            break;
                    }
                </div>
                <div class="card-body">
                    <form method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Input.Placa" />

                        <fieldset disabled="@(isLocked ? "disabled" : null)">
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label asp-for="Input.Placa" class="form-label fw-bold">Placa</label>
                                    <input asp-for="Input.Placa" class="form-control bg-light" readonly />
                                </div>
                                <div class="col-md-8 mb-3">
                                    <label asp-for="Input.Modelo" class="form-label fw-bold">Modelo / Carroceria</label>
                                    <input asp-for="Input.Modelo" class="form-control" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.ChassiNumero" class="form-label fw-bold">Chassi</label>
                                    <input asp-for="Input.ChassiNumero" class="form-control" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.Renavan" class="form-label fw-bold">Renavam</label>
                                    <input asp-for="Input.Renavan" class="form-control" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="Input.AnoFabricacao" class="form-label fw-bold">Ano Fab.</label>
                                    <input asp-for="Input.AnoFabricacao" type="number" class="form-control" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="Input.ModeloAno" class="form-label fw-bold">Ano Mod.</label>
                                    <input asp-for="Input.ModeloAno" type="number" class="form-control" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="Input.NumeroLugares" class="form-label fw-bold">Lugares</label>
                                    <input asp-for="Input.NumeroLugares" type="number" class="form-control" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.VeiculoCombustivelNome" class="form-label fw-bold">Combustível</label>
                                    <select asp-for="Input.VeiculoCombustivelNome" class="form-select">
                                        <option value="DIESEL">Diesel</option>
                                        <option value="GASOLINA">Gasolina</option>
                                        <option value="FLEX">Flex</option>
                                        <option value="ALCOOL">Álcool</option>
                                        <option value="GNV">GNV</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.PotenciaMotor" class="form-label fw-bold">Potência (CV)</label>
                                    <input asp-for="Input.PotenciaMotor" class="form-control" />
                                </div>
                            </div>

                            <div class="d-flex justify-content-end gap-2 mt-4 border-top pt-3">
                                <a href="/Empresa/MeusVeiculos" class="btn btn-outline-secondary">Voltar</a>
                                @if (!isLocked)
                                {
                                    <button type="submit" class="btn btn-primary px-4">Salvar Alterações</button>
                                }
                            </div>
                        </fieldset>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow border-0">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="bi bi-file-earmark-pdf me-2"></i>Documentação do Veículo</h5>
                </div>
                <div class="card-body bg-light">

                    @{
                        async Task RenderDocSection(string title, string type, List<Eva.Models.Documento> docs)
                        {
                            <div class="mb-4 pb-3 border-bottom">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="fw-bold text-secondary mb-0">@title</h6>
                                    @* Interface Fix: Mimics Empresa behavior - only show button if no document exists *@
                                    @if (!isLocked && !docs.Any())
                                    {
                                        <button class="btn btn-sm btn-outline-primary" onclick="triggerUpload('@type')">
                                            <i class="bi bi-upload"></i> Enviar Novo
                                        </button>
                                    }
                                </div>

                                @if (!docs.Any())
                                {
                                    <div class="text-muted small fst-italic ms-1"><i class="bi bi-exclamation-circle"></i> Pendente de envio</div>
                                }
                                else
                                {
                                    <ul class="list-group list-group-flush shadow-sm rounded">
                                        @foreach (var doc in docs)
                                        {
                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                <div class="text-truncate me-2" title="@doc.NomeArquivo">
                                                    <i class="bi bi-file-earmark-check text-success me-1"></i>
                                                    <small class="fw-bold">@doc.NomeArquivo</small>
                                                    <div class="text-muted" style="font-size: 0.75rem">
                                                        @doc.DataUpload.ToString("dd/MM/yyyy HH:mm")
                                                    </div>
                                                </div>
                                                @if (!isLocked)
                                                {
                                                    @* Bug Fix: Added asp-route-id and renamed input to 'docId' for clarity *@
                                                    <form method="post" asp-page-handler="DeleteDoc" asp-route-id="@Model.Input.Placa" class="d-inline">
                                                        <input type="hidden" name="docId" value="@doc.Id" />
                                                        <button type="submit" class="btn btn-link text-danger p-0 border-0" title="Excluir">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                }
                                            </li>
                                        }
                                    </ul>
                                }
                            </div>
                        }
                    }

                    @{
                        await RenderDocSection("CRLV (Documento)", "CRLV", Model.Crlvs);
                    }
                    @{
                        await RenderDocSection("Apólice de Seguro", "APOLICE_SEGURO", Model.Apolices);
                    }
                    @{
                        await RenderDocSection("Laudo de Inspeção", "LAUDO_INSPECAO", Model.Laudos);
                    }
                    @{
                        await RenderDocSection("Comprovante de Pagamento", "COMPROVANTE_PAGAMENTO", Model.Comprovantes);
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@* Bug Fix: Added asp-route-id so Upload handler receives the plaque *@
<form id="uploadForm" method="post" enctype="multipart/form-data" asp-page-handler="Upload" asp-route-id="@Model.Input.Placa" style="display:none">
    <input type="hidden" asp-for="TipoDocumentoUpload" id="tipoDocInput" />
    <input type="file" asp-for="UploadArquivo" id="fileInput" accept=".pdf" onchange="document.getElementById('uploadForm').submit()" />
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function triggerUpload(type) {
            document.getElementById('tipoDocInput').value = type;
            document.getElementById('fileInput').click();
        }
    </script>
}