@page "{id}"
@model Eva.Pages.Empresa.EditarVeiculoModel
@{
    ViewData["Title"] = "Editar Veículo - Fretamento Eventual";
    bool isLocked = Model.PendenciaStatus == WorkflowStatus.EmAnalise;
}

<div class="container mt-5 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Empresa/MinhaEmpresa">Painel</a></li>
            <li class="breadcrumb-item"><a href="/Empresa/MeusVeiculos">Meus Veículos</a></li>
            <li class="breadcrumb-item active">Editar</li>
        </ol>
    </nav>

    @if (isLocked)
    {
        <div class="alert alert-warning mb-4 shadow-sm" role="alert">
            <i class="bi bi-lock-fill me-2"></i>
            <strong>Acesso Bloqueado:</strong> Este veículo está em análise por um analista e não pode ser alterado no momento.
        </div>
    }

    @if (Model.PendenciaStatus == "REJEITADO" && !string.IsNullOrEmpty(Model.RejeicaoMotivo))
    {
        <div class="alert alert-danger mb-4 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Atenção (Cadastro Rejeitado):</strong><span class="preserve-newlines"> @Model.RejeicaoMotivo</span>
        </div>
    }

    <div class="row">
        <div class="col-lg-7">
            <div class="card shadow mb-4">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Dados do Veículo</h5>
                    @switch (Model.PendenciaStatus)
                    {
                        case WorkflowStatus.Incompleto:
                            <span class="badge @WorkflowStatus.GetBadgeClass(Model.PendenciaStatus) border border-light"><i class="bi @WorkflowStatus.GetBadgeIcon(Model.PendenciaStatus)"></i> @WorkflowStatus.GetDisplayLabel(Model.PendenciaStatus)</span>
                            break;
                        case WorkflowStatus.AguardandoAnalise:
                            <span class="badge @WorkflowStatus.GetBadgeClass(Model.PendenciaStatus) border border-light"><i class="bi @WorkflowStatus.GetBadgeIcon(Model.PendenciaStatus)"></i> @WorkflowStatus.GetDisplayLabel(Model.PendenciaStatus)</span>
                            break;
                        case WorkflowStatus.EmAnalise:
                            <span class="badge @WorkflowStatus.GetBadgeClass(Model.PendenciaStatus) border border-light"><i class="bi @WorkflowStatus.GetBadgeIcon(Model.PendenciaStatus)"></i> @WorkflowStatus.GetDisplayLabel(Model.PendenciaStatus)</span>
                            break;
                        case WorkflowStatus.Aprovado:
                            <span class="badge @WorkflowStatus.GetBadgeClass(Model.PendenciaStatus) border border-light"><i class="bi @WorkflowStatus.GetBadgeIcon(Model.PendenciaStatus)"></i> @WorkflowStatus.GetDisplayLabel(Model.PendenciaStatus)</span>
                            break;
                        case WorkflowStatus.Rejeitado:
                            <span class="badge @WorkflowStatus.GetBadgeClass(Model.PendenciaStatus) border border-light"><i class="bi @WorkflowStatus.GetBadgeIcon(Model.PendenciaStatus)"></i> @WorkflowStatus.GetDisplayLabel(Model.PendenciaStatus)</span>
                            break;
                    }
                </div>
                <div class="card-body">
                    <form method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Input.Placa" />

                        <fieldset disabled="@(isLocked ? "disabled" : null)">
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label asp-for="Input.Placa" class="form-label fw-bold">Placa</label>
                                    <input asp-for="Input.Placa" class="form-control bg-light" readonly />
                                </div>
                                <div class="col-md-8 mb-3">
                                    <label asp-for="Input.Modelo" class="form-label fw-bold">Modelo / Carroceria</label>
                                    <input asp-for="Input.Modelo" class="form-control" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.ChassiNumero" class="form-label fw-bold">Chassi</label>
                                    <input asp-for="Input.ChassiNumero" class="form-control" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.Renavan" class="form-label fw-bold">Renavam</label>
                                    <input asp-for="Input.Renavan" class="form-control" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="Input.AnoFabricacao" class="form-label fw-bold">Ano Fab.</label>
                                    <input asp-for="Input.AnoFabricacao" type="number" class="form-control" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="Input.ModeloAno" class="form-label fw-bold">Ano Mod.</label>
                                    <input asp-for="Input.ModeloAno" type="number" class="form-control" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="Input.NumeroLugares" class="form-label fw-bold">Lugares</label>
                                    <input asp-for="Input.NumeroLugares" type="number" class="form-control" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.VeiculoCombustivelNome" class="form-label fw-bold">Combustível</label>
                                    <select asp-for="Input.VeiculoCombustivelNome" class="form-select">
                                        <option value="DIESEL">Diesel</option>
                                        <option value="GASOLINA">Gasolina</option>
                                        <option value="FLEX">Flex</option>
                                        <option value="ALCOOL">Álcool</option>
                                        <option value="GNV">GNV</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.PotenciaMotor" class="form-label fw-bold">Potência (CV)</label>
                                    <input asp-for="Input.PotenciaMotor" class="form-control" />
                                </div>
                            </div>

                            <div class="d-flex justify-content-end gap-2 mt-4 border-top pt-3">
                                <a href="/Empresa/MeusVeiculos" class="btn btn-outline-secondary">Voltar</a>
                                @if (!isLocked)
                                {
                                    <button type="submit" class="btn btn-primary px-4">Salvar Alterações</button>
                                }
                            </div>
                        </fieldset>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow border-0">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="bi bi-file-earmark-pdf me-2"></i>Documentação do Veículo</h5>
                </div>
                <div class="card-body bg-light" id="doc-section-container">
                    <partial name="_VeiculoDocs" model="Model" />
                </div>
            </div>
        </div>
    </div>
</div>

<form id="uploadForm" method="post" enctype="multipart/form-data" asp-page-handler="Upload" asp-route-id="@Model.Input.Placa" style="display:none">
    <input type="hidden" asp-for="TipoDocumentoUpload" id="tipoDocInput" />
    <input type="file" asp-for="UploadArquivo" id="fileInput" accept=".pdf"
           onchange="evaPerformAsyncAction('uploadForm', 'doc-section-container')" />
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function triggerUpload(type) {
            evaTriggerUpload(type, 'tipoDocInput', 'fileInput');
        }
    </script>
}


