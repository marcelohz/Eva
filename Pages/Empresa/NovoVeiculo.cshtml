@page
@model Eva.Pages.Empresa.NovoVeiculoModel
@{
    ViewData["Title"] = "Novo Veículo - Eva";
}

<div class="container mt-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Empresa/MinhaEmpresa">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/Empresa/MeusVeiculos">Meus Veículos</a></li>
            <li class="breadcrumb-item active">Novo</li>
        </ol>
    </nav>

    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h1 class="h4 mb-0">Cadastrar Novo Veículo</h1>
        </div>
        <div class="card-body">
            <form method="post">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Veiculo.Placa" class="form-label">Placa</label>
                        <input asp-for="Veiculo.Placa" class="form-control text-uppercase" placeholder="ABC1234" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Veiculo.Modelo" class="form-label">Modelo / Marca</label>
                        <input asp-for="Veiculo.Modelo" class="form-control" placeholder="Ex: Marcopolo Paradiso" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Veiculo.ChassiNumero" class="form-label">Chassi</label>
                        <input asp-for="Veiculo.ChassiNumero" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Veiculo.Renavan" class="form-label">Renavam</label>
                        <input asp-for="Veiculo.Renavan" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Veiculo.AnoFabricacao" class="form-label">Ano Fabricação</label>
                        <input asp-for="Veiculo.AnoFabricacao" type="number" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Veiculo.ModeloAno" class="form-label">Ano Modelo</label>
                        <input asp-for="Veiculo.ModeloAno" type="number" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Veiculo.NumeroLugares" class="form-label">Nº de Lugares</label>
                        <input asp-for="Veiculo.NumeroLugares" type="number" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Veiculo.VeiculoCombustivelNome" class="form-label">Combustível</label>
                        <select asp-for="Veiculo.VeiculoCombustivelNome" class="form-select">
                            <option value="">Selecione...</option>
                            <option value="DIESEL">Diesel</option>
                            <option value="GASOLINA">Gasolina</option>
                            <option value="ALCOOL">Álcool</option>
                            <option value="ELETRICO">Elétrico</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Veiculo.CorPrincipalNome" class="form-label">Cor Principal</label>
                        <input asp-for="Veiculo.CorPrincipalNome" class="form-control" />
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a href="/Empresa/MeusVeiculos" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-success px-4">Salvar Veículo</button>
                </div>
            </form>
        </div>
    </div>
</div>