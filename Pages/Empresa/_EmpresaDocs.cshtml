@model Eva.Pages.Empresa.EditarEmpresaModel
@{
    // SAFETY LOCK 1: Prevents the "Inception" bug
    Layout = null;
    bool isLocked = Model.PendenciaStatus == "EM_ANALISE";

    async Task RenderDocSection(string title, string type, List<Eva.Models.Documento> docs, bool multiple = false)
    {
        <div class="mb-4 pb-3 border-bottom">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="fw-bold text-secondary mb-0">@title</h6>
                @if (!isLocked && (multiple || !docs.Any()))
                {
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="triggerUpload('@type')">
                        <i class="bi bi-upload"></i> Enviar Novo
                    </button>
                }
            </div>

            @if (!docs.Any())
            {
                <div class="text-muted small fst-italic ms-1"><i class="bi bi-exclamation-circle"></i> Pendente de envio</div>
            }
            else
            {
                <ul class="list-group list-group-flush shadow-sm rounded">
                    @foreach (var doc in docs)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div class="text-truncate me-2" title="@doc.NomeArquivo">
                                <i class="bi bi-file-earmark-check text-success me-1"></i>
                                <small class="fw-bold">@doc.NomeArquivo</small>
                                <div class="text-muted" style="font-size: 0.75rem">
                                    @doc.DataUpload.ToString("dd/MM/yyyy HH:mm")
                                </div>
                            </div>
                            @if (!isLocked)
                            {
                                <form id="deleteForm-@doc.Id" method="post" asp-page-handler="DeleteDoc" class="d-inline">
                                    <input type="hidden" name="id" value="@doc.Id" />
                                    <button type="button" class="btn btn-link text-danger p-0 border-0" title="Excluir" onclick="evaPerformAsyncAction('deleteForm-@doc.Id', 'doc-section-container')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </li>
                    }
                </ul>
            }
        </div>
    }
}

@{
    await RenderDocSection("Cartão CNPJ", "CARTAO_CNPJ", Model.CartoesCnpj);
}
@{
    await RenderDocSection("Contrato Social", "CONTRATO_SOCIAL", Model.Contratos);
}
@{
    await RenderDocSection("Identidade dos Sócios", "IDENTIDADE_SOCIO", Model.IdentidadesSocios, true);
}
@{
    await RenderDocSection("Alvará", "ALVARA", Model.Alvaras);
}
@{
    await RenderDocSection("CNAE Fiscal", "CNAE_FISCAL", Model.Cnaes);
}