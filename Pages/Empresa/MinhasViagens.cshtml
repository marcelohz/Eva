@page
@model Eva.Pages.Empresa.MinhasViagensModel
@{
    ViewData["Title"] = "Minhas Viagens - Eva";
}

<div class="container mt-5 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Empresa/MinhaEmpresa">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Minhas Viagens</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">Gestão de Viagens</h1>
            <p class="text-muted">Consulte e gerencie as viagens eventuais cadastradas pela sua empresa.</p>
        </div>
        <a href="/Empresa/NovaViagem" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Nova Viagem
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Protocolo</th>
                            <th>Situação</th>
                            <th>Contratante</th>
                            <th>Placa</th>
                            <th>Origem</th>
                            <th>Destino</th>
                            <th>Data / Hora Saída</th>
                            <th>Data / Hora Retorno</th>
                            <th class="text-end pe-4">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Viagens == null || !Model.Viagens.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center py-5 text-muted">
                                    <i class="bi bi-geo-alt display-4 d-block mb-2 text-secondary opacity-50"></i>
                                    Nenhuma viagem encontrada.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var v in Model.Viagens)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-secondary">
                                        #@v.Id.ToString("D5")
                                    </td>
                                    <td>
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Registrada</span>
                                    </td>
                                    <td>
                                        <span class="d-inline-block text-truncate" style="max-width: 150px;" title="@v.NomeContratante">
                                            @v.NomeContratante
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-dark text-uppercase p-2" style="letter-spacing: 1px;">
                                            @v.VeiculoPlaca
                                        </span>
                                    </td>
                                    <td>@v.MunicipioOrigem</td>
                                    <td>@v.MunicipioDestino</td>
                                    <td>
                                        <i class="bi bi-calendar-event text-muted me-1"></i> @v.IdaEm.ToLocalTime().ToString("dd/MM/yyyy")<br />
                                        <small class="text-muted"><i class="bi bi-clock me-1"></i> @v.IdaEm.ToLocalTime().ToString("HH:mm")</small>
                                    </td>
                                    <td>
                                        <i class="bi bi-calendar-event text-muted me-1"></i> @v.VoltaEm.ToLocalTime().ToString("dd/MM/yyyy")<br />
                                        <small class="text-muted"><i class="bi bi-clock me-1"></i> @v.VoltaEm.ToLocalTime().ToString("HH:mm")</small>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            <button type="button" class="btn btn-sm btn-outline-primary" title="Visualizar Detalhes">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-danger" title="Baixar PDF">
                                                <i class="bi bi-file-earmark-pdf"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>