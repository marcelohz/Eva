@page "{id:int}"
@model Eva.Pages.Empresa.EditarViagemModel
@{
    ViewData["Title"] = $"{Model.ActionLabel} Viagem - Fretamento Eventual";
}

<div class="container mt-5 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Empresa/MinhaEmpresa">Painel</a></li>
            <li class="breadcrumb-item"><a href="/Empresa/MinhasViagens">Minhas Viagens</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.ActionLabel</li>
        </ol>
    </nav>

    <div class="mb-4">
        <h1 class="h3 mb-0">@Model.ActionLabel da Viagem #@Model.Id.ToString("D5")</h1>
        <p class="text-muted">Gerencie os dados da viagem conforme as regras atuais de pagamento e prazo.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ModeMessage))
    {
        <div class="alert @(Model.IsReadOnly ? "alert-secondary" : "alert-info") shadow-sm" role="alert">
            @Model.ModeMessage
        </div>
    }

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm"></div>

        <div class="row g-4">
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-dark text-white rounded-top">
                        <h5 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i> 1. Dados do Contrato</h5>
                    </div>
                    <div class="card-body bg-light">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label asp-for="Input.ViagemTipoNome" class="form-label fw-bold">Tipo de Viagem <span class="text-danger">*</span></label>
                                <select asp-for="Input.ViagemTipoNome" asp-items="Model.ViagemTipos" class="form-select shadow-sm" disabled="@(!Model.CanEditFull)">
                                    <option value="">-- Selecione o Tipo --</option>
                                </select>
                                <span asp-validation-for="Input.ViagemTipoNome" class="text-danger small"></span>
                            </div>
                            <div class="col-md-5">
                                <label asp-for="Input.NomeContratante" class="form-label fw-bold">Nome do Contratante <span class="text-danger">*</span></label>
                                <input asp-for="Input.NomeContratante" class="form-control shadow-sm" readonly="@(!Model.CanEditFull)" />
                                <span asp-validation-for="Input.NomeContratante" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Input.CpfCnpjContratante" class="form-label fw-bold">CPF/CNPJ Contratante <span class="text-danger">*</span></label>
                                <input asp-for="Input.CpfCnpjContratante" class="form-control shadow-sm" readonly="@(!Model.CanEditFull)" />
                                <span asp-validation-for="Input.CpfCnpjContratante" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0"><i class="bi bi-map me-2"></i> 2. Logística e Itinerário</h5>
                    </div>
                    <div class="card-body bg-light">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Input.IdaEm" class="form-label fw-bold">Data/Hora de Saída <span class="text-danger">*</span></label>
                                <input asp-for="Input.IdaEm" type="datetime-local" class="form-control shadow-sm" readonly="@(!Model.CanEditFull)" />
                                <span asp-validation-for="Input.IdaEm" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.VoltaEm" class="form-label fw-bold">Data/Hora de Retorno <span class="text-danger">*</span></label>
                                <input asp-for="Input.VoltaEm" type="datetime-local" class="form-control shadow-sm" readonly="@(!Model.CanEditFull)" />
                                <span asp-validation-for="Input.VoltaEm" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Input.RegiaoCodigo" class="form-label fw-bold">Região de Operação <span class="text-danger">*</span></label>
                                <select asp-for="Input.RegiaoCodigo" asp-items="Model.Regioes" class="form-select shadow-sm" id="Input_RegiaoCodigo" disabled="@(!Model.CanEditFull)">
                                    <option value="">-- Selecione a Região --</option>
                                </select>
                                <span asp-validation-for="Input.RegiaoCodigo" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Input.MunicipioOrigem" class="form-label fw-bold">Município de Origem <span class="text-danger">*</span></label>
                                <select asp-for="Input.MunicipioOrigem" class="form-select shadow-sm" id="Input_MunicipioOrigem" disabled="@(!Model.CanEditFull)">
                                    <option value="">-- Selecione o Município --</option>
                                </select>
                                <span asp-validation-for="Input.MunicipioOrigem" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Input.MunicipioDestino" class="form-label fw-bold">Município de Destino <span class="text-danger">*</span></label>
                                <select asp-for="Input.MunicipioDestino" class="form-select shadow-sm" id="Input_MunicipioDestino" disabled="@(!Model.CanEditFull)">
                                    <option value="">-- Selecione o Município --</option>
                                </select>
                                <span asp-validation-for="Input.MunicipioDestino" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Input.Descricao" class="form-label fw-bold">Descrição / Observações</label>
                                <textarea asp-for="Input.Descricao" class="form-control shadow-sm" rows="2" readonly="@(!Model.CanEditFull)"></textarea>
                                <span asp-validation-for="Input.Descricao" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0"><i class="bi bi-bus-front me-2"></i> 3. Veículo e Motoristas</h5>
                    </div>
                    <div class="card-body bg-light">
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label asp-for="Input.VeiculoPlaca" class="form-label fw-bold">Veículo <span class="text-danger">*</span></label>
                                <select asp-for="Input.VeiculoPlaca" asp-items="Model.Veiculos" class="form-select shadow-sm" disabled="@(!Model.CanEditFull)">
                                    <option value="">-- Selecione o Veículo --</option>
                                </select>
                                <span asp-validation-for="Input.VeiculoPlaca" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.MotoristaId" class="form-label fw-bold">Motorista Principal <span class="text-danger">*</span></label>
                                <select asp-for="Input.MotoristaId" asp-items="Model.Motoristas" class="form-select shadow-sm" disabled="@(!Model.CanEditFull)">
                                    <option value="">-- Selecione o Motorista --</option>
                                </select>
                                <span asp-validation-for="Input.MotoristaId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.MotoristaAuxId" class="form-label fw-bold">Motorista Auxiliar (Opcional)</label>
                                <select asp-for="Input.MotoristaAuxId" asp-items="Model.Motoristas" class="form-select shadow-sm" disabled="@(!Model.CanEditFull)">
                                    <option value="">-- Nenhum --</option>
                                </select>
                                <span asp-validation-for="Input.MotoristaAuxId" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card shadow-sm border-0 border-primary">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-people me-2"></i> 4. Lista de Passageiros</h5>
                        @if (!Model.IsReadOnly)
                        {
                            <button type="button" class="btn btn-sm btn-light text-primary fw-bold" id="btnAdicionarPassageiro">
                                <i class="bi bi-plus-lg"></i> Adicionar Passageiro
                            </button>
                        }
                    </div>
                    <div class="card-body p-0">
                        <span asp-validation-for="Input.Passageiros" class="text-danger small d-block p-3"></span>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" id="tabelaPassageiros">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4" style="width: 50%;">Nome Completo</th>
                                        <th style="width: 40%;">Documento (CPF/RG)</th>
                                        <th class="text-center" style="width: 10%;">Ação</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Input.Passageiros != null && Model.Input.Passageiros.Any())
                                    {
                                        for (int i = 0; i < Model.Input.Passageiros.Count; i++)
                                        {
                                            <tr>
                                                <td class="ps-4">
                                                    <input type="text" name="Input.Passageiros[@i].Nome" value="@Model.Input.Passageiros[i].Nome" class="form-control form-control-sm" required readonly="@Model.IsReadOnly" />
                                                </td>
                                                <td>
                                                    <input type="text" name="Input.Passageiros[@i].Documento" value="@Model.Input.Passageiros[i].Documento" class="form-control form-control-sm" required readonly="@Model.IsReadOnly" />
                                                </td>
                                                <td class="text-center">
                                                    @if (!Model.IsReadOnly)
                                                    {
                                                        <button type="button" class="btn btn-sm btn-outline-danger btn-remove-passenger" title="Remover">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div id="emptyPassengersMessage" class="p-4 text-center text-muted">
                            <i class="bi bi-person-x display-6 d-block mb-2"></i>
                            Nenhum passageiro adicionado. Clique no botão acima para começar.
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 d-flex justify-content-between align-items-center mt-4 border-top pt-4">
                <a href="/Empresa/MinhasViagens" class="btn btn-outline-secondary btn-lg shadow-sm">Voltar</a>
                @if (!Model.IsReadOnly)
                {
                    <button type="submit" class="btn btn-success btn-lg shadow">
                        Salvar Alterações <i class="bi bi-check-circle ms-1"></i>
                    </button>
                }
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const canEditFull = @(Model.CanEditFull ? "true" : "false");
            const isReadOnly = @(Model.IsReadOnly ? "true" : "false");

            const selectRegiao = document.getElementById('Input_RegiaoCodigo');
            const selectOrigem = document.getElementById('Input_MunicipioOrigem');
            const selectDestino = document.getElementById('Input_MunicipioDestino');
            const selectedOrigem = '@Html.Raw(Model.Input.MunicipioOrigem)';
            const selectedDestino = '@Html.Raw(Model.Input.MunicipioDestino)';

            async function carregarMunicipios(regiaoCodigo, valOrigem, valDestino) {
                selectOrigem.innerHTML = '<option value="">-- Carregando... --</option>';
                selectDestino.innerHTML = '<option value="">-- Carregando... --</option>';

                if (!regiaoCodigo) {
                    selectOrigem.innerHTML = '<option value="">-- Selecione o Município --</option>';
                    selectDestino.innerHTML = '<option value="">-- Selecione o Município --</option>';
                    return;
                }

                const response = await fetch(`?handler=Municipios&regiaoCodigo=${regiaoCodigo}`);
                const data = await response.json();

                selectOrigem.innerHTML = '<option value="">-- Selecione o Município --</option>';
                selectDestino.innerHTML = '<option value="">-- Selecione o Município --</option>';

                data.forEach(m => {
                    selectOrigem.add(new Option(m.text, m.value));
                    selectDestino.add(new Option(m.text, m.value));
                });

                if (valOrigem) selectOrigem.value = valOrigem;
                if (valDestino) selectDestino.value = valDestino;
            }

            if (selectRegiao && selectRegiao.value) {
                carregarMunicipios(selectRegiao.value, selectedOrigem, selectedDestino);
            }

            if (canEditFull && selectRegiao) {
                selectRegiao.addEventListener('change', function () {
                    carregarMunicipios(this.value, '', '');
                });
            }

            const tableBody = document.querySelector('#tabelaPassageiros tbody');
            const btnAdd = document.getElementById('btnAdicionarPassageiro');
            const emptyMessage = document.getElementById('emptyPassengersMessage');
            let passengerIndex = @(Model.Input.Passageiros?.Count ?? 0);

            function toggleEmptyMessage() {
                if (tableBody.children.length === 0) {
                    emptyMessage.style.display = 'block';
                    tableBody.parentElement.style.display = 'none';
                } else {
                    emptyMessage.style.display = 'none';
                    tableBody.parentElement.style.display = 'table';
                }
            }

            function addPassengerRow() {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td class="ps-4">
                        <input type="text" name="Input.Passageiros[${passengerIndex}].Nome" class="form-control form-control-sm" required />
                    </td>
                    <td>
                        <input type="text" name="Input.Passageiros[${passengerIndex}].Documento" class="form-control form-control-sm" required />
                    </td>
                    <td class="text-center">
                        <button type="button" class="btn btn-sm btn-outline-danger btn-remove-passenger" title="Remover">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                `;
                tableBody.appendChild(tr);
                passengerIndex++;
                toggleEmptyMessage();
            }

            function reindexPassengers() {
                const rows = tableBody.querySelectorAll('tr');
                passengerIndex = rows.length;

                rows.forEach((row, newIndex) => {
                    const inputs = row.querySelectorAll('input');
                    inputs.forEach(input => {
                        const oldName = input.getAttribute('name');
                        if (oldName) {
                            input.setAttribute('name', oldName.replace(/\[\d+\]/, `[${newIndex}]`));
                        }
                    });
                });
            }

            if (!isReadOnly) {
                if (btnAdd) {
                    btnAdd.addEventListener('click', addPassengerRow);
                }

                tableBody.addEventListener('click', function (e) {
                    if (e.target.closest('.btn-remove-passenger')) {
                        e.target.closest('tr').remove();
                        reindexPassengers();
                        toggleEmptyMessage();
                    }
                });
            }

            toggleEmptyMessage();
        });
    </script>
}
