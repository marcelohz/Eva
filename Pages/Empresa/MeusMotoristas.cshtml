@page
@model Eva.Pages.Empresa.MeusMotoristasModel
@{
    ViewData["Title"] = "Meus Motoristas - Eva";
}

<div class="container mt-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Empresa/MinhaEmpresa">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Meus Motoristas</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">Quadro de Motoristas</h1>
            <p class="text-muted">Gerencie os motoristas vinculados à sua empresa.</p>
        </div>
        <a href="/Empresa/NovoMotorista" class="btn btn-primary">
            <i class="bi bi-person-plus"></i> Novo Motorista
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Nome</th>
                            <th>CPF</th>
                            <th>CNH</th>
                            <th>E-mail</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Motoristas == null || !Model.Motoristas.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-person-badge display-4 d-block mb-2"></i>
                                    Nenhum motorista encontrado.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var m in Model.Motoristas)
                            {
                                var health = Model.HealthReports.ContainsKey(m.Id.ToString()) ?
                                    Model.HealthReports[m.Id.ToString()] : new Eva.Models.EntityHealthReport();
                                var isLocked = health.IsLocked;

                                <tr>
                                    <td class="ps-4 fw-bold text-secondary">
                                        @m.Nome
                                    </td>
                                    <td>@m.Cpf</td>
                                    <td>@m.Cnh</td>
                                    <td>@(m.Email ?? "-")</td>
                                    <td>
                                        @if (health.IsLegal)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Legalizado</span>
                                        }
                                        else if (health.CurrentStatus == "AGUARDANDO_ANALISE")
                                        {
                                            <span class="badge bg-warning text-dark"><i class="bi bi-clock-history"></i> Aguardando Análise</span>
                                        }
                                        else if (health.CurrentStatus == "EM_ANALISE")
                                        {
                                            <span class="badge bg-info text-dark"><i class="bi bi-hourglass-split"></i> Em Análise</span>
                                        }
                                        else if (health.AnalystStatus == "REJEITADO")
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Rejeitado</span>
                                        }
                                        else if (health.AnalystStatus == "INCOMPLETO")
                                        {
                                            <span class="badge bg-secondary"><i class="bi bi-file-earmark"></i> Incompleto</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-exclamation-triangle"></i> Bloqueado</span>
                                            <div class="small text-muted mt-1">
                                                @if (health.MissingMandatoryDocs.Any())
                                                {
                                                    <span>Falta doc</span>
                                                }
                                                @if (health.ExpiredDocs.Any())
                                                {
                                                    <span>Doc Vencido</span>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            <a href="/Empresa/EditarMotorista/@m.Id" class="btn btn-sm btn-outline-primary @(isLocked ? "disabled" : "")" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-outline-danger" title="Excluir" data-bs-toggle="modal" data-bs-target="#deleteModal" data-id="@m.Id" data-nome="@m.Nome" @(isLocked ? "disabled" : "")>
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel"><i class="bi bi-exclamation-triangle-fill"></i> Confirmar Exclusão</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Tem certeza que deseja excluir o motorista <strong id="modalMotoristaNome"></strong>?</p>
                <p class="text-danger small mb-0">Esta ação não pode ser desfeita.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form method="post" asp-page-handler="Delete">
                    <input type="hidden" name="id" id="modalInputId" value="" />
                    <button type="submit" class="btn btn-danger">Sim, Excluir</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var deleteModal = document.getElementById('deleteModal')
        deleteModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget
            var id = button.getAttribute('data-id')
            var nome = button.getAttribute('data-nome')

            var modalNomeText = deleteModal.querySelector('#modalMotoristaNome')
            var modalInputId = deleteModal.querySelector('#modalInputId')

            modalNomeText.textContent = nome
            modalInputId.value = id
        })
    </script>
}