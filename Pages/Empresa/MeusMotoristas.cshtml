@page
@model Eva.Pages.Empresa.MeusMotoristasModel
@{
    ViewData["Title"] = "Meus Motoristas - Eva";
}

<div class="container mt-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Empresa/MinhaEmpresa">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Meus Motoristas</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">Motoristas Cadastrados</h1>
        <a href="/Empresa/NovoMotorista" class="btn btn-primary">
            <i class="bi bi-person-plus"></i> Novo Motorista
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Nome</th>
                            <th>CPF</th>
                            <th>CNH</th>
                            <th>Email</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Motoristas.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">
                                    Nenhum motorista encontrado para sua empresa.
                                </td>
                            </tr>
                        }
                        @foreach (var m in Model.Motoristas)
                        {
                            <tr>
                                <td class="fw-bold">@m.Nome</td>
                                <td>@m.Cpf</td>
                                <td>@m.Cnh</td>
                                <td>@m.Email</td>
                                <td class="text-end">
                                    <a href="/Empresa/EditarMotorista/@m.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>