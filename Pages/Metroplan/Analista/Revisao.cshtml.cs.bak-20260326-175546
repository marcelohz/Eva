        private async Task LoadDataAsync()
        {
            Submissao = await _context.Submissoes.FirstOrDefaultAsync(s => s.Id == SubmissaoId);
            if (Submissao == null)
            {
                return;
            }

            DadosSubmissao = await _context.SubmissaoDados.FirstOrDefaultAsync(sd => sd.SubmissaoId == SubmissaoId);
            if (DadosSubmissao == null)
            {
                return;
            }

            AnalistaAtual = User.FindFirstValue(ClaimTypes.Email) ?? _currentUserService.GetCurrentEmail() ?? string.Empty;
            IsLockedByMe = Submissao.Status == SubmissaoWorkflow.EmAnalise && string.Equals(Submissao.AnalistaAtual, AnalistaAtual, StringComparison.OrdinalIgnoreCase);
            IsLockedByOther = Submissao.Status == SubmissaoWorkflow.EmAnalise && !string.Equals(Submissao.AnalistaAtual, AnalistaAtual, StringComparison.OrdinalIgnoreCase);

            Historico = await _context.SubmissaoEventos
                .Where(e => e.SubmissaoId == SubmissaoId)
                .OrderByDescending(e => e.CriadoEm)
                .ThenByDescending(e => e.Id)
                .ToListAsync();

            await LoadEntityAndDraftDataAsync();
            await LoadDocumentosAsync();

            HasRejectedItems =
                DadosSubmissao.StatusRevisao == SubmissaoWorkflow.RevisaoRejeitada ||
                DocumentosRevisao.SelectMany(g => g.Itens).Any(i => i.StatusRevisao == SubmissaoWorkflow.RevisaoRejeitada);
        }

        private async Task LoadEntityAndDraftDataAsync()
        {
            var jsonOpts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            switch (Submissao!.EntidadeTipo)
            {
                case "VEICULO":
                    Veiculo = await _context.Veiculos.IgnoreQueryFilters()
                        .Include(v => v.Empresa)
                        .FirstOrDefaultAsync(v => v.Placa == Submissao.EntidadeId);
                    VeiculoDraft = JsonSerializer.Deserialize<VeiculoVM>(DadosSubmissao!.DadosPropostos, jsonOpts);
                    break;

                case "MOTORISTA" when int.TryParse(Submissao.EntidadeId, out var motoristaId):
                    Motorista = await _context.Motoristas.IgnoreQueryFilters()
                        .Include(m => m.Empresa)
                        .FirstOrDefaultAsync(m => m.Id == motoristaId);
                    MotoristaDraft = JsonSerializer.Deserialize<MotoristaVM>(DadosSubmissao!.DadosPropostos, jsonOpts);
                    break;

                case "EMPRESA":
                    Empresa = await _context.Empresas.IgnoreQueryFilters()
                        .FirstOrDefaultAsync(e => e.Cnpj == Submissao.EntidadeId);
                    EmpresaDraft = JsonSerializer.Deserialize<EmpresaVM>(DadosSubmissao!.DadosPropostos, jsonOpts);
                    break;
            }
        }

        private async Task LoadDocumentosAsync()
        {
            var regrasEsperadas = await _context.DocumentoTipoVinculos
                .Include(v => v.DocumentoTipo)
                .Where(v => v.EntidadeTipo == Submissao!.EntidadeTipo)
                .OrderBy(v => v.TipoNome)
                .ToListAsync();

            var docsSubmissao = await _context.SubmissaoDocumentos
                .Where(sd => sd.SubmissaoId == SubmissaoId && sd.AtivoNaSubmissao)
                .OrderBy(sd => sd.DocumentoTipoNome)
                .ThenBy(sd => sd.Id)
                .ToListAsync();

            var docIds = docsSubmissao.Select(sd => sd.DocumentoId).Distinct().ToList();
            var documentos = await _context.Documentos
                .Where(d => docIds.Contains(d.Id))
                .ToDictionaryAsync(d => d.Id, d => d);

            DocumentosRevisao = regrasEsperadas.Select(regra => new DocumentoRevisaoGrupoVm
            {
                TipoNome = regra.TipoNome,
                Obrigatorio = regra.DocumentoTipo?.Obrigatorio ?? false,
                PermiteMultiplos = regra.DocumentoTipo?.PermiteMultiplos ?? false,
                Itens = docsSubmissao
                    .Where(sd => sd.DocumentoTipoNome == regra.TipoNome)
                    .Select(sd => new DocumentoRevisaoItemVm
                    {
                        SubmissaoDocumentoId = sd.Id,
                        Documento = documentos[sd.DocumentoId],
                        StatusRevisao = sd.StatusRevisao,
                        MotivoRejeicao = sd.MotivoRejeicao,
                        ValidadeInformada = sd.ValidadeInformada,
                        CarregadoDeDocumentoAtual = sd.CarregadoDeDocumentoAtual
                    })
                    .ToList()
            }).ToList();

            var tiposEsperados = regrasEsperadas.Select(r => r.TipoNome).ToHashSet();
            foreach (var grupoExtra in docsSubmissao.Where(sd => !tiposEsperados.Contains(sd.DocumentoTipoNome)).GroupBy(sd => sd.DocumentoTipoNome))
            {
                DocumentosRevisao.Add(new DocumentoRevisaoGrupoVm
                {
                    TipoNome = grupoExtra.Key,
                    Obrigatorio = false,
                    PermiteMultiplos = grupoExtra.Count() > 1,
                    Itens = grupoExtra.Select(sd => new DocumentoRevisaoItemVm
                    {
                        SubmissaoDocumentoId = sd.Id,
                        Documento = documentos[sd.DocumentoId],
                        StatusRevisao = sd.StatusRevisao,
                        MotivoRejeicao = sd.MotivoRejeicao,
                        ValidadeInformada = sd.ValidadeInformada,
                        CarregadoDeDocumentoAtual = sd.CarregadoDeDocumentoAtual
                    }).ToList()
                });
            }

            DocumentosRevisao = DocumentosRevisao
                .OrderByDescending(g => g.Obrigatorio)
                .ThenBy(g => g.TipoNome)
                .ToList();
        }
