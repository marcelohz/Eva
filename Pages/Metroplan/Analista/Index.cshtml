@page
@model Eva.Pages.Metroplan.Analista.IndexModel
@{
    ViewData["Title"] = "Fila de Análise - Eva";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h1 class="h2"><i class="bi bi-inboxes-fill text-primary me-2"></i>Fila de Análise</h1>
            <p class="text-muted">Tickets aguardando verificação de documentos e dados.</p>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Data da Solicitação</th>
                            <th>Tipo</th>
                            <th>Identificador</th>
                            <th>Status</th>
                            <th>Atribuído A</th>
                            <th class="text-end pe-4">Ação</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Fila.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-check2-circle display-4 d-block mb-2 text-success"></i>
                                    A fila está vazia! Excelente trabalho.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.Fila)
                            {
                                bool isMyLock = item.Status == "EM_ANALISE" && item.Analista == Model.AnalistaAtual;
                                bool isLockedByOther = item.Status == "EM_ANALISE" && item.Analista != Model.AnalistaAtual;

                                <tr class="@(isMyLock ? "table-info" : "")">
                                    <td class="ps-4">@item.CriadoEm.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <span class="badge bg-secondary text-uppercase">@item.EntidadeTipo</span>
                                    </td>
                                    <td class="fw-bold">@item.EntidadeId</td>
                                    <td>
                                        @if (item.Status == "AGUARDANDO_ANALISE")
                                        {
                                            <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> Aguardando</span>
                                        }
                                        else if (item.Status == "EM_ANALISE")
                                        {
                                            <span class="badge bg-info text-dark"><i class="bi bi-lock-fill"></i> Em Análise</span>
                                        }
                                    </td>
                                    <td>
                                        @if (isLockedByOther)
                                        {
                                            <span class="text-danger small"><i class="bi bi-person-fill-lock"></i> @item.Analista</span>
                                        }
                                        else if (isMyLock)
                                        {
                                            <span class="text-primary small fw-bold">Você</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">-</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="/Metroplan/Analista/Revisao?tipo=@item.EntidadeTipo&id=@item.EntidadeId"
                                           class="btn btn-sm btn-primary">
                                            <i class="bi bi-eye"></i> Visualizar
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>