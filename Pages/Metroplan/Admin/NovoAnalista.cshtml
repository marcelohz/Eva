@page
@model Eva.Pages.Metroplan.Admin.NovoAnalistaModel
@{
    ViewData["Title"] = "Novo Analista - Eva";
}

<div class="container mt-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Metroplan/Admin">Painel Admin</a></li>
            <li class="breadcrumb-item active">Novo Analista</li>
        </ol>
    </nav>

    <div class="card shadow" style="max-width: 600px; margin: 0 auto;">
        <div class="card-header bg-dark text-white">
            <h1 class="h4 mb-0">Cadastrar Novo Analista</h1>
        </div>
        <div class="card-body">
            <form method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Input.Nome" class="form-label fw-bold">Nome Completo</label>
                    <input asp-for="Input.Nome" class="form-control" placeholder="João da Silva" />
                    <span asp-validation-for="Input.Nome" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label fw-bold">E-mail Institucional</label>
                    <input asp-for="Input.Email" type="email" class="form-control" placeholder="joao.silva@metroplan.rs.gov.br" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.Senha" class="form-label fw-bold">Senha Provisória</label>
                    <input asp-for="Input.Senha" type="password" class="form-control" />
                    <span asp-validation-for="Input.Senha" class="text-danger small"></span>
                    <div class="form-text">Forneça esta senha para o analista realizar o primeiro acesso.</div>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-3">
                    <a href="/Metroplan/Admin" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary px-4">Salvar Analista</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}