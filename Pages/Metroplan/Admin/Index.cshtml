@page
@model Eva.Pages.Metroplan.Admin.IndexModel
@{
    ViewData["Title"] = "Painel Admin - Eva";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h1 class="h2"><i class="bi bi-shield-lock-fill text-warning me-2"></i>Painel Administrativo</h1>
            <p class="text-muted">Visão geral e gerenciamento do sistema.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6 col-lg-4">
            <a href="/Metroplan/Admin/Analistas" class="text-decoration-none">
                <div class="card h-100 shadow-sm border-0 hover-card">
                    <div class="card-body text-center p-4">
                        <div class="mb-3">
                            <i class="bi bi-people-fill text-primary display-4"></i>
                        </div>
                        <h5 class="card-title text-dark fw-bold mb-2">Gerenciar Analistas</h5>
                        <p class="card-text text-muted">
                            Visualizar, editar e adicionar analistas responsáveis pela avaliação de documentos.
                        </p>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col-md-6 col-lg-4">
            <a href="/Metroplan/Analista/Index" class="text-decoration-none">
                <div class="card h-100 shadow-sm border-0 hover-card">
                    <div class="card-body text-center p-4">
                        <div class="mb-3">
                            <i class="bi bi-file-earmark-check-fill text-success display-4"></i>
                        </div>
                        <h5 class="card-title text-dark fw-bold mb-2">Área de Análise</h5>
                        <p class="card-text text-muted">
                            Acessar a fila de documentos e aprovar ou reprovar cadastros como um analista.
                        </p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    .hover-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
</style>