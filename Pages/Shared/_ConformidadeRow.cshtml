@model (Eva.Models.ViewModels.ConformidadeEntidadeVM Entidade, string EditUrl)

<tr>
    <td class="fw-bold text-dark">@Model.Entidade.Nome</td>
    
    <td>
        <span class="badge @WorkflowStatus.GetBadgeClass(Model.Entidade.StatusGeral) rounded-pill">
            @WorkflowStatus.GetDisplayLabel(Model.Entidade.StatusGeral)
        </span>
        @if (Model.Entidade.PossuiTentativaRejeitada)
        {
            <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill ms-1">Última tentativa rejeitada</span>
        }
    </td>

    <td>
        @if (Model.Entidade.StatusGeral == WorkflowStatus.Aprovado && !Model.Entidade.PossuiTentativaRejeitada)
        {
            <span class="text-muted small"><i class="bi bi-check2"></i> @WorkflowStatus.GetConformidadeHint(Model.Entidade.StatusGeral)</span>
        }
        else if (WorkflowStatus.IsPending(Model.Entidade.StatusGeral))
        {
            <span class="text-muted small"><i class="bi bi-hourglass-split"></i> @WorkflowStatus.GetConformidadeHint(Model.Entidade.StatusGeral)</span>
        }
        else
        {
            <div class="d-flex flex-column gap-1">
                @if (!string.IsNullOrEmpty(Model.Entidade.MotivoRejeicao))
                {
                    <div class="text-danger small preserve-newlines">
                        <strong>Motivo da última rejeição:</strong> @Model.Entidade.MotivoRejeicao
                    </div>
                }
                
                <div class="d-flex flex-wrap gap-1">
                    @foreach (var doc in Model.Entidade.DocumentosEmAnalise)
                    {
                        <span class="badge bg-info text-dark border"><i class="bi bi-hourglass-split"></i> Em análise: @doc</span>
                    }
                    @foreach (var doc in Model.Entidade.DocumentosFaltantes)
                    {
                        <span class="badge bg-warning text-dark border"><i class="bi bi-file-earmark-x"></i> Falta: @doc</span>
                    }
                    @foreach (var doc in Model.Entidade.DocumentosVencidos)
                    {
                        <span class="badge bg-danger border"><i class="bi bi-calendar-x"></i> Vencido: @doc</span>
                    }
                </div>
            </div>
        }
    </td>

    <td class="text-end">
        @if (Model.Entidade.IsBlocked)
        {
            <a href="@Model.EditUrl" class="btn btn-sm btn-danger">Resolver</a>
        }
        else
        {
            <a href="@Model.EditUrl" class="btn btn-sm btn-outline-primary">Acessar</a>
        }
    </td>
</tr>


