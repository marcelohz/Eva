@model (Eva.Models.ViewModels.ConformidadeEntidadeVM Entidade, string EditUrl)

<tr>
    <td class="fw-bold text-dark">@Model.Entidade.Nome</td>

    <td>
        <span class="badge @WorkflowStatus.GetBadgeClass(Model.Entidade.SituacaoOperacional) rounded-pill">
            @WorkflowStatus.GetDisplayLabel(Model.Entidade.SituacaoOperacional)
        </span>
    </td>

    <td>
        <span class="badge @SubmissaoWorkflow.GetBadgeClass(Model.Entidade.UltimaSubmissao) rounded-pill">
            @SubmissaoWorkflow.GetDisplayLabel(Model.Entidade.UltimaSubmissao)
        </span>
    </td>

    <td>
        @if (Model.Entidade.SituacaoOperacional == WorkflowStatus.Aprovado && !Model.Entidade.PossuiTentativaRejeitada)
        {
            <span class="text-muted small"><i class="bi bi-check2"></i> @WorkflowStatus.GetConformidadeHint(Model.Entidade.SituacaoOperacional)</span>
        }
        else if (Model.Entidade.UltimaSubmissao == SubmissaoWorkflow.AguardandoAnalise || Model.Entidade.UltimaSubmissao == SubmissaoWorkflow.EmAnalise)
        {
            <span class="text-muted small"><i class="bi bi-hourglass-split"></i> @SubmissaoWorkflow.GetDisplayLabel(Model.Entidade.UltimaSubmissao)</span>
        }
        else
        {
            <div class="d-flex flex-column gap-1">
                @if (!string.IsNullOrEmpty(Model.Entidade.MotivoRejeicao))
                {
                    <div class="text-danger small preserve-newlines">
                        <strong>Motivo da &uacute;ltima rejei&ccedil;&atilde;o:</strong> @Model.Entidade.MotivoRejeicao
                    </div>
                }

                <div class="d-flex flex-wrap gap-1">
                    @foreach (var doc in Model.Entidade.DocumentosEmAnalise)
                    {
                        <span class="badge bg-info text-dark border"><i class="bi bi-hourglass-split"></i> Em an&aacute;lise: @doc</span>
                    }
                    @foreach (var doc in Model.Entidade.DocumentosFaltantes)
                    {
                        <span class="badge bg-warning text-dark border"><i class="bi bi-file-earmark-x"></i> Falta: @doc</span>
                    }
                    @foreach (var doc in Model.Entidade.DocumentosVencidos)
                    {
                        <span class="badge bg-danger border"><i class="bi bi-calendar-x"></i> Vencido: @doc</span>
                    }
                </div>
            </div>
        }
    </td>

    <td class="text-end">
        @if (Model.Entidade.IsBlocked)
        {
            <a href="@Model.EditUrl" class="btn btn-sm btn-danger">Resolver</a>
        }
        else
        {
            <a href="@Model.EditUrl" class="btn btn-sm btn-outline-primary">Acessar</a>
        }
    </td>
</tr>
