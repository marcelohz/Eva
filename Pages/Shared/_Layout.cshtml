<!DOCTYPE html>
@using System.Reflection
@{
    var appVersion = Assembly.GetEntryAssembly()?
        .GetCustomAttribute<AssemblyInformationalVersionAttribute>()?
        .InformationalVersion ?? "0.1.0";
}
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @inject Microsoft.AspNetCore.Authorization.IAuthorizationService AuthorizationService

    <header>
        <nav class="navbar navbar-expand-lg navbar-light app-navbar border-bottom box-shadow mb-3">
            <div class="container navbar-shell">
                <a class="navbar-logo-link" asp-area="" asp-page="/Index" aria-label="Página inicial">
                    <img src="~/images/logo-metroplan.png" asp-append-version="true" alt="Metroplan" class="header-logo header-logo-metroplan" />
                </a>

                <div class="navbar-center">
                    <button class="navbar-toggler ms-auto app-navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse" id="mainNavbar">
                        <div class="navbar-menu-wrap">
                            <ul class="navbar-nav flex-grow-1 justify-content-lg-center">

                                @if ((await AuthorizationService.AuthorizeAsync(User, null, "AcessoEmpresa")).Succeeded)
                                {
                                    <li class="nav-item">
                                        <a class="nav-link app-nav-link" href="/Empresa/MinhaEmpresa">Painel</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link app-nav-link" href="/Empresa/MeusVeiculos">Veículos</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link app-nav-link" href="/Empresa/MeusMotoristas">Motoristas</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link app-nav-link" href="/Empresa/MinhasViagens">Viagens</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link app-nav-link" href="/Empresa/EditarEmpresa">Empresa</a>
                                    </li>

                                    @if (User.IsInRole("EMPRESA"))
                                    {
                                        <li class="nav-item">
                                            <a class="nav-link app-nav-link" href="/Empresa/MeusUsuarios">Usuários</a>
                                        </li>
                                    }
                                }

                                @if (User.IsInRole("ANALISTA"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link app-nav-link fw-bold" href="/Metroplan/Analista"><i class="bi bi-inboxes-fill"></i> Fila de Análise</a>
                                    </li>
                                }

                                @if (User.IsInRole("ADMIN"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link app-nav-link app-nav-link-admin fw-bold" href="/Metroplan/Admin"><i class="bi bi-shield-lock-fill"></i> Painel Admin</a>
                                    </li>
                                }
                            </ul>

                            <ul class="navbar-nav navbar-user-menu">
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <li class="nav-item">
                                        <span class="nav-link app-nav-user">Olá, @User.Identity.Name</span>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link app-nav-link" href="/Logout">Sair</a>
                                    </li>
                                }
                                else
                                {
                                    <li class="nav-item">
                                        <a class="nav-link app-nav-link" href="/Login">Entrar</a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>

                <a class="navbar-logo-link" asp-area="" asp-page="/Index" aria-label="Página inicial">
                    <img src="~/images/brasao-rs.png" asp-append-version="true" alt="Brasão do Rio Grande do Sul" class="header-logo header-logo-rs" />
                </a>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center app-footer-copy">
            <div>&copy; 2026 - METROPLAN</div>
            <div>Fretamento Eventual</div>
            <div class="app-version">v@(appVersion)</div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
