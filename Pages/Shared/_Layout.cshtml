<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Eva</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-primary border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-page="/Index">EVA</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.IsInRole("EMPRESA"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/Empresa/MinhaEmpresa">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/Empresa/MeusVeiculos">Veículos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/Empresa/MeusMotoristas">Motoristas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/Empresa/MinhasViagens">Viagens</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/Empresa/EditarEmpresa">Empresa</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/Empresa/MeusUsuarios">Usuários</a>
                            </li>
                        }

                        @if (User.IsInRole("ANALISTA"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white fw-bold" href="/Metroplan/Analista"><i class="bi bi-inboxes-fill"></i> Fila de Análise</a>
                            </li>
                        }

                        @if (User.IsInRole("ADMIN"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning fw-bold" href="/Metroplan/Admin"><i class="bi bi-shield-lock-fill"></i> Painel Admin</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-white-50">Olá, @User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/Logout">Sair</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/Login">Entrar</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center">
            &copy; 2026 - Eva Metroplan
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>